      "card": {
        "value": { "x": "0", "y": "2", "blur": "12", "spread": "0", "color": "rgba(30,43,77,0.10)", "type": "dropShadow" },
        "type": "boxShadow", "description": "Cards"
      },
      "floating": {
        "value": { "x": "0", "y": "8", "blur": "24", "spread": "0", "color": "rgba(30,43,77,0.22)", "type": "dropShadow" },
        "type": "boxShadow", "description": "Floating / modal elements"
      },
      "nav": {
        "value": { "x": "0", "y": "4", "blur": "20", "spread": "0", "color": "rgba(13,11,97,0.30)", "type": "dropShadow" },
