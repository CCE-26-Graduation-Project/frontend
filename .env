# Frontend → backend connection (Expo public env vars).
# Copy to `.env` and adjust. Anything prefixed EXPO_PUBLIC_ is readable in app code
# via process.env.* (see services/config.ts).

# springboot-api (product search, /api/*). Default: http://localhost:8080
# Android emulator uses 10.0.2.2 automatically; a physical device needs your LAN IP, e.g.:
#   EXPO_PUBLIC_API_BASE_URL=http://192.168.1.20:8080
# EXPO_PUBLIC_API_BASE_URL=http://localhost:8080,http://192.168.1.29:8080


# When switching to iOS physical device, change to:
EXPO_PUBLIC_API_BASE_URL=https://springboot-gradproject.azurewebsites.net
EXPO_PUBLIC_AUTH_BASE_URL=https://nodeauth-gradproject.azurewebsites.net
EXPO_PUBLIC_API_TIMEOUT_MS=120000

# # For testing on web browser:
# EXPO_PUBLIC_API_BASE_URL=http://localhost:8080
# EXPO_PUBLIC_AUTH_BASE_URL=http://localhost:3001
# EXPO_PUBLIC_API_TIMEOUT_MS=30000


# # node-auth (SuperTokens, /auth/*). Default: http://localhost:3001
# EXPO_PUBLIC_AUTH_BASE_URL=http://localhost:3001,http://192.168.1.29:3001,http://192.168.1.29:8080


